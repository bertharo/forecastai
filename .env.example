# Local Homebrew (default on this machine — no password):
DATABASE_URL=postgresql://bertharo@127.0.0.1:5432/meter
# Docker Compose alternative:
# DATABASE_URL=postgresql://meter:meter@127.0.0.1:5432/meter
# Production (Vercel + Neon): set DATABASE_URL in the Vercel project env
# (vercel install neon). Never commit production credentials.
NEXT_PUBLIC_APP_NAME=Meter

# Optional: encrypt connector API keys (AES-GCM)
# METER_CREDENTIALS_KEY=

# After db:seed, open the Northstar demo in Workspaces with token:
# ws_demo_northstar
